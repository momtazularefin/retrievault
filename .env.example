# retrievault - Environment Configuration
# DO NOT COMMIT actual secrets to .env!

# LLM Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
RETRIEVAULT_SYNTHESIS_MODEL=claude-sonnet-4-6

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# Corpus Configuration
CORPUS_REPO=fastapi/fastapi
CORPUS_TAG=0.136.3

# Retrieval Parameters (defaults)
PREFETCH_LIMIT=50
TOP_N_FUSION=30
TOP_K_RERANK=6
